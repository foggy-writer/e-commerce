# Allow browser PUT updates specifically for orders.json
# Requires Apache modules: mod_dav, mod_dav_fs, mod_authz_core

<IfModule mod_dav.c>
  Dav On
</IfModule>

# Default: block write-style methods for everything in /admin
<FilesMatch "^(?!orders\.json$).*$">
  <Limit PUT DELETE PATCH MKCOL COPY MOVE PROPFIND PROPPATCH LOCK UNLOCK>
    Require all denied
  </Limit>
</FilesMatch>

# Allow write methods only for orders.json
<Files "orders.json">
  Require all granted
  <Limit PUT OPTIONS>
    Require all granted
  </Limit>
</Files>
